{
  "database_implementation": {
    "tables": {
      "users": {
        "description": "Stores all system users.",
        "fields": {
          "id": "primary_key",
          "name": "string|required",
          "role": "enum_or_role_id|required",
          "email": "string|unique|nullable",
          "phone": "string|nullable",
          "profile_image": "string_path|nullable",
          "qr_code": "string_or_path|unique|nullable",
          "classroom_id": "foreign_key|nullable",
          "status": "enum:active,inactive,suspended|default:active",
          "created_at": "timestamp",
          "updated_at": "timestamp"
        },
        "indexes": ["email", "role", "classroom_id", "status", "qr_code"]
      },
      "classrooms": {
        "description": "Stores classroom, group, or section records.",
        "fields": {
          "id": "primary_key",
          "name": "string|required",
          "teacher_id": "foreign_key_users|nullable",
          "description": "text|nullable",
          "status": "enum:active,inactive|default:active",
          "created_at": "timestamp",
          "updated_at": "timestamp"
        },
        "indexes": ["teacher_id", "status"]
      },
      "attendance": {
        "description": "Stores attendance records.",
        "fields": {
          "id": "primary_key",
          "user_id": "foreign_key_users|required",
          "classroom_id": "foreign_key_classrooms|nullable",
          "date": "date|required",
          "time_in": "time|nullable",
          "time_out": "time|nullable",
          "status": "enum:Present,Absent,Late,Excused|required",
          "remarks": "text|nullable",
          "recorded_by": "foreign_key_users|required",
          "created_at": "timestamp",
          "updated_at": "timestamp",
          "deleted_at": "timestamp|nullable"
        },
        "indexes": ["user_id", "classroom_id", "date", "status", "recorded_by"],
        "unique_rules": ["user_id + classroom_id + date", "user_id + classroom_id + date + session_id if session tracking is used"]
      },
      "notifications": {
        "description": "Stores email and SMS notification records.",
        "fields": {
          "id": "primary_key",
          "user_id": "foreign_key_users|required",
          "type": "enum:email,sms|required",
          "message": "text|required",
          "status": "enum:pending,sent,failed,read|default:pending",
          "sent_at": "timestamp|nullable",
          "created_at": "timestamp",
          "updated_at": "timestamp"
        },
        "indexes": ["user_id", "type", "status", "sent_at"]
      },
      "roles": {
        "description": "Optional normalized role table.",
        "fields": {
          "id": "primary_key",
          "name": "string|unique|required",
          "description": "text|nullable",
          "created_at": "timestamp",
          "updated_at": "timestamp"
        }
      },
      "imports": {
        "description": "Stores bulk import logs.",
        "fields": {
          "id": "primary_key",
          "uploaded_by": "foreign_key_users",
          "file_name": "string",
          "type": "enum:users,attendance",
          "status": "enum:pending,processing,completed,failed",
          "total_rows": "integer",
          "successful_rows": "integer",
          "failed_rows": "integer",
          "error_log": "json|nullable",
          "created_at": "timestamp",
          "updated_at": "timestamp"
        }
      },
      "exports": {
        "description": "Stores report export logs.",
        "fields": {
          "id": "primary_key",
          "exported_by": "foreign_key_users",
          "type": "string",
          "format": "enum:Excel,PDF",
          "file_path": "string|nullable",
          "filters": "json|nullable",
          "created_at": "timestamp"
        }
      },
      "audit_logs": {
        "description": "Tracks sensitive actions and record changes.",
        "fields": {
          "id": "primary_key",
          "user_id": "foreign_key_users|nullable",
          "action": "string|required",
          "model": "string|nullable",
          "model_id": "integer|nullable",
          "old_values": "json|nullable",
          "new_values": "json|nullable",
          "ip_address": "string|nullable",
          "user_agent": "text|nullable",
          "created_at": "timestamp"
        },
        "indexes": ["user_id", "action", "model", "model_id", "created_at"]
      },
      "attendance_sessions": {
        "description": "Optional table for class session or event-based attendance.",
        "fields": {
          "id": "primary_key",
          "classroom_id": "foreign_key_classrooms|required",
          "title": "string|nullable",
          "date": "date|required",
          "start_time": "time|nullable",
          "end_time": "time|nullable",
          "created_by": "foreign_key_users",
          "created_at": "timestamp",
          "updated_at": "timestamp"
        }
      }
    },
    "implementation_notes": {
      "recommended_practices": [
        "Use soft deletes for users and attendance records.",
        "Use audit logs for corrections and deletions.",
        "Use policies or gates for role permissions.",
        "Use queues for SMS and email sending.",
        "Use scheduled commands for reminders and report generation.",
        "Validate imports before saving records.",
        "Index frequently filtered fields such as date, classroom_id, user_id, status, and role.",
        "Restrict staff reports to assigned classrooms or groups only."
      ],
      "suggested_laravel_modules": [
        "Auth",
        "RBAC",
        "Users",
        "Classrooms",
        "Attendance",
        "QR",
        "Notifications",
        "Reports",
        "Imports",
        "Exports",
        "AuditLogs",
        "Settings"
      ],
      "minimum_mvp": [
        "authentication",
        "role_permissions",
        "user_crud",
        "classroom_crud",
        "attendance_crud",
        "personal_attendance_view",
        "basic_reports",
        "export_excel_pdf"
      ],
      "phase_2": [
        "qr_scanning",
        "sms_notifications",
        "cron_reminders",
        "bulk_import",
        "print_layouts",
        "audit_logs"
      ],
      "phase_3": [
        "advanced_analytics",
        "event_tracking",
        "leave_request_workflow",
        "mobile_pwa",
        "dashboard_charts"
      ]
    }
  }
}
